# Docker Compose environment — copy to .env in repo root:
#   cp .env.docker.example .env
# Then run: docker compose up --build -d

# Replace with strong secrets in production: openssl rand -hex 32
JWT_SECRET=dev-change-me-use-openssl-rand-hex-32-in-production
NEXTAUTH_SECRET=dev-change-me-use-openssl-rand-hex-32-in-production

# S3 bucket created by minio-init (must match backend)
S3_BUCKET=agent-assist-dev

# Backend
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3000
# Rate limit: requests per user per minute (default in code: 200)
AGENT_GATEWAY_RATE_LIMIT_PER_USER=200

# Frontend (NEXT_PUBLIC_* baked at build time; API_SERVER_URL is runtime, for server-side auth → backend)
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=http://localhost:4000
NEXTAUTH_URL=http://localhost:3000
# API_SERVER_URL is set by docker-compose to http://backend:4000 so the frontend container can reach the API
# Auth.js v5: set in Docker / behind proxy to avoid UntrustedHost
AUTH_TRUST_HOST=true
