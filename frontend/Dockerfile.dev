# Dev image: install deps + build workspace packages only. Frontend app is
# mounted at runtime and run with `next dev` so code changes apply without rebuild.
FROM node:22-alpine
RUN corepack enable && corepack prepare pnpm@latest --activate
WORKDIR /app

ARG NEXT_PUBLIC_API_URL=http://localhost:4000
ARG NEXT_PUBLIC_WS_URL=http://localhost:4000
ARG NEXTAUTH_URL=http://localhost:3000
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL \
    NEXT_PUBLIC_WS_URL=$NEXT_PUBLIC_WS_URL \
    NEXTAUTH_URL=$NEXTAUTH_URL

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY frontend ./frontend
COPY packages ./packages

RUN pnpm install --frozen-lockfile && \
    pnpm --filter shared-types build && \
    pnpm --filter plugin-sdk build
# Do NOT run: pnpm --filter frontend build

COPY frontend/docker-dev-entrypoint.sh /app/docker-dev-entrypoint.sh
RUN chmod +x /app/docker-dev-entrypoint.sh

WORKDIR /app/frontend
EXPOSE 3000
ENV HOSTNAME=0.0.0.0
ENV AUTH_TRUST_HOST=true
ENTRYPOINT ["/app/docker-dev-entrypoint.sh"]
