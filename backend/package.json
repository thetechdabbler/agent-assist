{
  "name": "backend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:contract": "vitest run --config vitest.contract.config.ts",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.540.0",
    "@aws-sdk/s3-request-presigner": "^3.540.0",
    "@fastify/cors": "^9.0.0",
    "@opensearch-project/opensearch": "^2.7.0",
    "@opentelemetry/api": "^1.8.0",
    "@opentelemetry/exporter-prometheus": "^0.51.0",
    "@opentelemetry/sdk-metrics": "^1.24.0",
    "@opentelemetry/sdk-node": "^0.51.0",
    "@opentelemetry/sdk-trace-node": "^1.24.0",
    "@prisma/client": "^5.11.0",
    "async-retry": "^1.3.3",
    "fastify": "^4.26.0",
    "ioredis": "^5.3.2",
    "jose": "^5.2.4",
    "opossum": "^8.1.0",
    "pino": "^8.19.0",
    "pino-pretty": "^11.0.0",
    "qrcode": "^1.5.3",
    "socket.io": "^4.7.4",
    "socket.io-redis": "^6.1.1",
    "@socket.io/redis-adapter": "^8.3.0",
    "zod": "^3.22.4",
    "plugin-sdk": "workspace:*",
    "shared-types": "workspace:*"
  },
  "devDependencies": {
    "@types/async-retry": "^1.4.8",
    "@types/node": "^20.11.0",
    "@types/opossum": "^8.1.4",
    "@types/qrcode": "^1.5.5",
    "prisma": "^5.11.0",
    "supertest": "^6.3.4",
    "testcontainers": "^10.7.0",
    "tsx": "^4.7.0",
    "vitest": "^1.4.0"
  }
}
