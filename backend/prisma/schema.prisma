// Agent Chat Workspace — Prisma schema
// All 13 entities per data-model.md; multi-tenant isolation via tenant_id

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Tenants ─────────────────────────────────────────────────────────────────

model Tenant {
  id         String   @id @default(uuid()) @db.Uuid
  name       String   @map("name")
  slug       String   @unique @map("slug")
  configJson Json?    @map("config_json") @db.JsonB
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  users           User[]
  conversations   Conversation[]
  goals           Goal[]
  jobs            Job[]
  notifications   Notification[]
  tenantPlugins   TenantPlugin[]
  auditLogs       AuditLog[]
  artifacts       Artifact[]

  @@map("tenants")
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique @map("email")
  name      String?  @map("name")
  tenantId  String   @map("tenant_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversations  Conversation[]  @relation("ConversationOwner")
  goals          Goal[]
  notifications  Notification[]
  auditLogs      AuditLog[]

  @@index([tenantId])
  @@map("users")
}

// ─── Conversations ──────────────────────────────────────────────────────────

model Conversation {
  id             String    @id @default(uuid()) @db.Uuid
  title          String?   @map("title")
  ownerUserId    String    @map("owner_user_id") @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  activeGoalId   String?   @map("active_goal_id") @db.Uuid
  status         String    @map("status") // active | archived
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  ownerUser   User          @relation("ConversationOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  activeGoal  Goal?         @relation("ActiveGoal", fields: [activeGoalId], references: [id], onDelete: SetNull)
  messages    Message[]
  attachments Attachment[]
  goals       Goal[]        @relation("ConversationGoals")
  jobs        Job[]
  artifacts   Artifact[]

  @@index([ownerUserId, status])
  @@index([tenantId, status])
  @@map("conversations")
}

// ─── Messages ────────────────────────────────────────────────────────────────

model Message {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  sourceType     String   @map("source_type") // user | agent | system
  type           String   @map("type")
  version        String   @map("version")
  payloadJson    Json     @map("payload_json") @db.JsonB
  correlationId  String?  @map("correlation_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  conversation Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  attachments  Attachment[]

  @@index([conversationId, createdAt])
  @@index([correlationId])
  @@map("messages")
}

// ─── Attachments ─────────────────────────────────────────────────────────────

model Attachment {
  id                 String   @id @default(uuid()) @db.Uuid
  conversationId     String   @map("conversation_id") @db.Uuid
  messageId         String   @map("message_id") @db.Uuid
  storageKey         String   @map("storage_key")
  filename           String   @map("filename")
  mimeType           String   @map("mime_type")
  sizeBytes          BigInt   @map("size_bytes")
  malwareScanStatus  String   @map("malware_scan_status") // pending | clean | quarantined
  metadataJson       Json?    @map("metadata_json") @db.JsonB
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message      Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([messageId])
  @@map("attachments")
}

// ─── Goals ───────────────────────────────────────────────────────────────────

model Goal {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  conversationId String?   @map("conversation_id") @db.Uuid
  goalType       String    @map("goal_type") // directive | scheduled
  title          String    @map("title")
  description    String?   @map("description")
  status         String    @map("status") // active | completed | cancelled
  schedule       String?   @map("schedule") // cron; for goal_type = scheduled
  metadataJson   Json?     @map("metadata_json") @db.JsonB
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation  Conversation?  @relation("ConversationGoals", fields: [conversationId], references: [id], onDelete: SetNull)
  conversationsAsActive Conversation[] @relation("ActiveGoal")
  jobs          Job[]

  @@index([userId, status])
  @@index([tenantId, status])
  @@index([userId, goalType])
  @@map("goals")
}

// ─── Jobs ───────────────────────────────────────────────────────────────────

model Job {
  id              String    @id @default(uuid()) @db.Uuid
  conversationId  String    @map("conversation_id") @db.Uuid
  goalId          String?   @map("goal_id") @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  externalJobRef  String?   @map("external_job_ref")
  jobType         String    @map("job_type")
  status          String    @map("status") // scheduled | queued | running | waiting_for_input | completed | failed
  progressPercent Int?     @map("progress_percent")
  scheduleAt      DateTime? @map("schedule_at") @db.Timestamptz
  startedAt       DateTime? @map("started_at") @db.Timestamptz
  completedAt     DateTime? @map("completed_at") @db.Timestamptz
  inputRef        String?   @map("input_ref") @db.Uuid
  resultRef       String?   @map("result_ref") @db.Uuid
  errorCode       String?   @map("error_code")
  errorSummary    String?   @map("error_summary")
  retryCount      Int       @default(0) @map("retry_count")
  metadataJson    Json?     @map("metadata_json") @db.JsonB
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  goal         Goal?         @relation(fields: [goalId], references: [id], onDelete: SetNull)
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  artifacts    Artifact[]
  notifications Notification[]

  @@index([conversationId, status])
  @@index([tenantId, status])
  @@index([goalId])
  @@index([scheduleAt])
  @@map("jobs")
}

// ─── Artifacts ───────────────────────────────────────────────────────────────

model Artifact {
  id             String   @id @default(uuid()) @db.Uuid
  jobId          String   @map("job_id") @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  artifactType   String   @map("artifact_type") // table | chart | file | image | text
  title          String   @map("title")
  version        Int      @default(1) @map("version")
  storageUri     String?  @map("storage_uri")
  payloadJson    Json?    @map("payload_json") @db.JsonB
  previewJson    Json?    @map("preview_json") @db.JsonB
  schemaVersion  String   @map("schema_version")
  metadataJson   Json?    @map("metadata_json") @db.JsonB
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  job           Job          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  conversation  Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  notifications Notification[]

  @@index([jobId])
  @@index([conversationId])
  @@index([tenantId, artifactType])
  @@index([createdAt])
  @@map("artifacts")
}

// ─── Notifications ───────────────────────────────────────────────────────────

model Notification {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  conversationId String?   @map("conversation_id") @db.Uuid
  jobId          String?   @map("job_id") @db.Uuid
  artifactId     String?   @map("artifact_id") @db.Uuid
  category       String    @map("category") // informational | success | action_required | warning | failure
  title          String    @map("title")
  body           String?   @map("body")
  isRead         Boolean   @default(false) @map("is_read")
  deliveredAt    DateTime? @map("delivered_at") @db.Timestamptz
  acknowledgedAt DateTime? @map("acknowledged_at") @db.Timestamptz
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  job          Job?          @relation(fields: [jobId], references: [id], onDelete: SetNull)
  artifact     Artifact?     @relation(fields: [artifactId], references: [id], onDelete: SetNull)

  @@index([userId, isRead])
  @@index([tenantId])
  @@map("notifications")
}

// ─── Plugin Registry ────────────────────────────────────────────────────────

model PluginRegistry {
  id                   String    @id @default(uuid()) @db.Uuid
  pluginType           String    @map("plugin_type")
  pluginName           String    @map("plugin_name")
  version              String    @map("version")
  contractVersion      String    @map("contract_version")
  status               String    @map("status") // active | degraded | disabled
  configJson           Json?     @map("config_json") @db.JsonB
  healthLastCheckedAt  DateTime? @map("health_last_checked_at") @db.Timestamptz
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  tenantPlugins TenantPlugin[]

  @@unique([pluginType, pluginName])
  @@map("plugin_registry")
}

// ─── Tenant Plugins ──────────────────────────────────────────────────────────

model TenantPlugin {
  tenantId            String   @map("tenant_id") @db.Uuid
  pluginId            String   @map("plugin_id") @db.Uuid
  enabled             Boolean  @default(false) @map("enabled")
  configOverrideJson  Json?    @map("config_override_json") @db.JsonB
  enabledAt           DateTime? @map("enabled_at") @db.Timestamptz

  tenant Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plugin PluginRegistry @relation(fields: [pluginId], references: [id], onDelete: Cascade)

  @@id([tenantId, pluginId])
  @@map("tenant_plugins")
}

// ─── Audit Log ───────────────────────────────────────────────────────────────

model AuditLog {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  userId       String?  @map("user_id") @db.Uuid
  eventType    String   @map("event_type")
  entityType   String   @map("entity_type")
  entityId     String   @map("entity_id") @db.Uuid
  beforeState  String?  @map("before_state")
  afterState   String?  @map("after_state")
  correlationId String? @map("correlation_id") @db.Uuid
  metadataJson Json?    @map("metadata_json") @db.JsonB
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entityId, entityType])
  @@index([tenantId, createdAt])
  @@index([correlationId])
  @@map("audit_log")
}
